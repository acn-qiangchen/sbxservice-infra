# Example terraform.tfvars file for local development
# Copy this file to terraform.tfvars and update as needed

# AWS Configuration
aws_region  = "us-east-1"
aws_profile = "sbxservice-poc"  # Set to your local AWS profile

# Environment Settings
environment = "dev"
project_name = "sbxservice"

# VPC Configuration
vpc_cidr = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]

# HTTPS Configuration
enable_https = true
# ssl_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/12345678-1234-1234-1234-123456789012"
https_port = 443
redirect_http_to_https = true 